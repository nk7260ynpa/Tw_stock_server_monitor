        },
        {
          "expr": "rate(node_network_transmit_bytes_total{job=\"$job\",device!~\"lo|lo0|veth.*|docker.*|br-.*\"}[5m]) * 8",
          "legendFormat": "{{device}} 傳送",
          "refId": "B"
        }
