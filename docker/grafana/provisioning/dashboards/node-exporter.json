        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 20, "spanNulls": false },
          "unit": "bps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 61 },
      "id": 40,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "title": "網路流量",
