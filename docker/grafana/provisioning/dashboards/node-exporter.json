      },
      "title": "網路封包速率",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(node_network_receive_packets_total{job=\"$job\",device!~\"lo|lo0|veth.*|docker.*|br-.*\"}[5m])",
          "legendFormat": "{{device}} 接收",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_packets_total{job=\"$job\",device!~\"lo|lo0|veth.*|docker.*|br-.*\"}[5m])",
          "legendFormat": "{{device}} 傳送",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rank" },
            "properties": [
              { "id": "custom.width", "value": 60 },
              { "id": "displayName", "value": "#" },
              { "id": "unit", "value": "none" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "process_name" },
            "properties": [
              { "id": "displayName", "value": "程序名稱" },
              { "id": "unit", "value": "none" },
              { "id": "custom.width", "value": 280 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pid" },
            "properties": [
              { "id": "displayName", "value": "PID" },
              { "id": "unit", "value": "none" },
              { "id": "custom.width", "value": 100 }
