      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 52 },
      "id": 30,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "displayMode": "basic"
      },
      "title": "各磁碟分區使用率",
      "type": "bargauge",
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{job=\"$job\",fstype!~\"tmpfs|devfs|autofs|nullfs|overlay|selfowner|fuse.*|hfs\",mountpoint!~\"/host_mnt.*|/run.*|/oldroot.*|/System/Volumes/(VM|Preboot|Update|xarts|iSCPreboot|Hardware)|/Volumes/.*|/Library/Developer/CoreSimulator/.*\"} / node_filesystem_size_bytes{job=\"$job\",fstype!~\"tmpfs|devfs|autofs|nullfs|overlay|selfowner|fuse.*|hfs\",mountpoint!~\"/host_mnt.*|/run.*|/oldroot.*|/System/Volumes/(VM|Preboot|Update|xarts|iSCPreboot|Hardware)|/Volumes/.*|/Library/Developer/CoreSimulator/.*\"}) * 100",
          "legendFormat": "{{mountpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false },
          "unit": "Bps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 52 },
      "id": 31,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "title": "磁碟 I/O 速率",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{job=\"$job\"}[5m])",
          "legendFormat": "{{device}} 讀取",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{job=\"$job\"}[5m])",
          "legendFormat": "{{device}} 寫入",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 60 },
      "id": 104,
      "title": "網路",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
