{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "總覽",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "CPU 使用率",
      "type": "gauge",
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"$job\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "記憶體使用率",
      "type": "gauge",
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{job=\"$job\"} / node_memory_MemTotal_bytes{job=\"$job\"}) * 100",
          "legendFormat": "Memory",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "磁碟使用率",
      "type": "gauge",
      "targets": [
        {
          "expr": "max((1 - node_filesystem_avail_bytes{job=\"$job\",fstype!~\"tmpfs|devfs|autofs|nullfs|overlay|selfowner|fuse.*|hfs\",mountpoint!~\"/host_mnt.*|/run.*|/oldroot.*|/System/Volumes/(VM|Preboot|Update|xarts|iSCPreboot|Hardware)|/Volumes/.*|/Library/Developer/CoreSimulator/.*\"} / node_filesystem_size_bytes{job=\"$job\",fstype!~\"tmpfs|devfs|autofs|nullfs|overlay|selfowner|fuse.*|hfs\",mountpoint!~\"/host_mnt.*|/run.*|/oldroot.*|/System/Volumes/(VM|Preboot|Update|xarts|iSCPreboot|Hardware)|/Volumes/.*|/Library/Developer/CoreSimulator/.*\"}) * 100)",
          "legendFormat": "Disk",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "title": "系統運行時間",
      "type": "stat",
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds{job=\"$job\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "CPU",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 20,
            "spanNulls": false
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 10,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "title": "CPU 使用率趨勢",
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"$job\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "使用率",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 20,
            "stacking": { "mode": "normal" },
            "spanNulls": false
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 11,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "title": "CPU 各模式使用率",
      "type": "timeseries",
      "targets": [
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"$job\",mode=\"user\"}[5m])) * 100",
          "legendFormat": "user",
          "refId": "A"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"$job\",mode=\"system\"}[5m])) * 100",
          "legendFormat": "system",
          "refId": "B"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"$job\",mode=\"iowait\"}[5m])) * 100",
          "legendFormat": "iowait",
          "refId": "C"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"$job\",mode=\"steal\"}[5m])) * 100",
          "legendFormat": "steal",
          "refId": "D"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"$job\",mode=\"nice\"}[5m])) * 100",
          "legendFormat": "nice",
          "refId": "E"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"$job\",mode=\"irq\"}[5m])) * 100",
          "legendFormat": "irq",
          "refId": "F"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"$job\",mode=\"softirq\"}[5m])) * 100",
          "legendFormat": "softirq",
          "refId": "G"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 12,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "title": "系統負載 (Load Average)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "node_load1{job=\"$job\"}",
          "legendFormat": "1 分鐘",
          "refId": "A"
        },
        {
          "expr": "node_load5{job=\"$job\"}",
          "legendFormat": "5 分鐘",
          "refId": "B"
        },
        {
          "expr": "node_load15{job=\"$job\"}",
          "legendFormat": "15 分鐘",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 102,
      "title": "記憶體",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 20,
            "stacking": { "mode": "normal" },
            "spanNulls": false
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 20,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "title": "記憶體使用量",
      "type": "timeseries",
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{job=\"$job\"} - node_memory_MemAvailable_bytes{job=\"$job\"}",
          "legendFormat": "已使用",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{job=\"$job\"}",
          "legendFormat": "可用",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 20,
            "stacking": { "mode": "normal" },
            "spanNulls": false
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 21,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "title": "記憶體細項",
      "type": "timeseries",
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{job=\"$job\"} - node_memory_MemFree_bytes{job=\"$job\"} - node_memory_Buffers_bytes{job=\"$job\"} - node_memory_Cached_bytes{job=\"$job\"}",
          "legendFormat": "應用程式",
          "refId": "A"
        },
        {
          "expr": "node_memory_Buffers_bytes{job=\"$job\"}",
          "legendFormat": "Buffers",
          "refId": "B"
        },
        {
          "expr": "node_memory_Cached_bytes{job=\"$job\"}",
          "legendFormat": "Cached",
          "refId": "C"
        },
        {
          "expr": "node_memory_MemFree_bytes{job=\"$job\"}",
          "legendFormat": "Free",
          "refId": "D"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 20, "spanNulls": false },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 22,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "title": "Swap 使用量",
      "type": "timeseries",
      "targets": [
        {
          "expr": "node_memory_SwapTotal_bytes{job=\"$job\"} - node_memory_SwapFree_bytes{job=\"$job\"}",
          "legendFormat": "Swap 已使用",
          "refId": "A"
        },
        {
          "expr": "node_memory_SwapFree_bytes{job=\"$job\"}",
          "legendFormat": "Swap 可用",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rank" },
            "properties": [
              { "id": "custom.width", "value": 60 },
              { "id": "displayName", "value": "#" },
              { "id": "unit", "value": "none" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "process_name" },
            "properties": [
              { "id": "displayName", "value": "程序名稱" },
              { "id": "unit", "value": "none" },
              { "id": "custom.width", "value": 280 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pid" },
            "properties": [
              { "id": "displayName", "value": "PID" },
              { "id": "unit", "value": "none" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "記憶體 (RSS)" },
              { "id": "unit", "value": "bytes" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 536870912 },
                  { "color": "red", "value": 1073741824 }
                ]
              }},
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 41 },
      "id": 23,
      "options": {
        "showHeader": true,
        "sortBy": [
          { "desc": true, "displayName": "記憶體 (RSS)" }
        ],
        "footer": {
          "show": false
        }
      },
      "title": "記憶體使用量前 15 名程序",
      "description": "依據 RSS（Resident Set Size）排序的記憶體使用量前 15 名程序（僅 macOS Exporter 提供此指標）",
      "type": "table",
      "targets": [
        {
          "expr": "topk(15, node_top_memory_process_rss_bytes{job=\"macos-exporter\"})",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "rank": 0,
              "process_name": 1,
              "pid": 2,
              "Value": 3
            },
            "renameByName": {}
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 },
      "id": 103,
      "title": "磁碟",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
